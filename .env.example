# ============================================================
# MAWIBO — Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Database (Replit auto-provisions this; set manually for local dev) ──────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ─────────────────────────────────────────────────────────────────────
# Random secret for signing JWT tokens. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# ── OpenAI (for AI features — chat, journal, symptom check, etc.) ────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Used internally by the AI integration client (set to https://api.openai.com/v1 for direct OpenAI)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Expo / Mobile App ─────────────────────────────────────────────────────────
# Dev: set automatically by Replit. Production: set to your deployed API domain.
# Example: my-api.replit.app  (no https://, no trailing slash)
EXPO_PUBLIC_DOMAIN=

# For Vercel deployment: set to the full base URL of your Replit API server
# Example: https://my-api.replit.app
EXPO_PUBLIC_API_BASE_URL=

# Replit-specific (auto-set in Replit environment, not needed elsewhere)
# REPLIT_DEV_DOMAIN=
# REPLIT_EXPO_DEV_DOMAIN=
# REPL_ID=
