# ============================================================
# MAWIBO — Comprehensive .gitignore
# ============================================================

# Compiled output
dist/
tmp/
out-tsc/
static-build/
*.tsbuildinfo
build/

# Expo
.expo/
.expo-shared/
web-build/

# Dependencies
node_modules/

# Environment variables — NEVER commit real secrets
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# OS / Editor
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.launch
.project
.classpath
.c9/
.settings/

# Coverage / Testing
coverage/
.nyc_output/
*.lcov

# Misc
.sass-cache/
connect.lock
libpeerconnection.log
testem.log
typings/

# Vercel
.vercel/

# Replit (local agent/dev tooling — not part of the app)
.cache/
.local/

# Native mobile build artifacts
ios/
android/
*.ipa
*.apk
*.aab

# TypeScript declaration output (lib packages emit to dist/)
lib/*/dist/

# Generated API client (regenerated by codegen — don't edit manually)
# Uncomment if you want to exclude generated files:
# lib/api-client-react/src/generated/
# lib/api-zod/src/generated/
